<div class="card h-full">
  <div class="card-header">
    <div>
      <h2 class="text-base font-semibold text-slate-900">Pipeline mix</h2>
      <p class="text-xs text-slate-500">Stage distribution for the current slice.</p>
    </div>
  </div>

  <div class="card-body relative">
    {{#if (or (not this.from) (not this.to))}}
      <div class="h-72 flex flex-col items-center justify-center text-sm text-slate-400 bg-slate-50 rounded-xl border border-dashed border-slate-200">
        <svg class="w-8 h-8 mb-2 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span>Please select a date range to view the pipeline mix.</span>
      </div>
    {{else}}
      {{#if this.isLoading}}
      <div class="absolute inset-0 z-10 flex items-center justify-center bg-white/50 backdrop-blur-[1px] rounded-b-xl">
        <div class="flex flex-col items-center gap-2">
          <div class="w-8 h-8 border-4 border-slate-200 border-t-primary-600 rounded-full animate-spin"></div>
          <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">Loading data...</span>
        </div>
      </div>
    {{/if}}

    {{#if this.errorMessage}}
      <div class="h-72 flex items-center justify-center text-sm text-danger-600 bg-danger-50 rounded-xl border border-danger-100">
        {{this.errorMessage}}
      </div>
    {{else}}
      <div class="h-72"><canvas></canvas></div>
    {{/if}}
    {{/if}}
  </div>
</div>

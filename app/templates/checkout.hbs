<div class="max-w-xl mx-auto">
  <div class="card overflow-hidden">

    {{!-- Premium Header --}}
    <div class="bg-gradient-to-br from-primary-600 to-primary-800 px-8 py-10 text-center text-white">
      <span class="badge bg-white/20 text-white text-[10px] uppercase tracking-widest mb-4 inline-block">Pro Plan</span>
      <h2 class="text-3xl font-bold">Upgrade to Pro</h2>
      <p class="mt-2 text-primary-200 text-sm">Unlock advanced analytics, automations, and integrations.</p>
      <div class="mt-6 flex items-baseline justify-center gap-1">
        <span class="text-5xl font-extrabold">$99</span>
        <span class="text-lg text-primary-200">/month</span>
      </div>
    </div>

    {{!-- Form Body --}}
    <div class="card-body px-8 py-8 space-y-5">
      <div class="flex items-center justify-between">
        <h3 class="text-base font-semibold text-slate-900">
          Payment Information
          <span class="text-xs text-slate-400 font-normal ml-1">(Demo)</span>
        </h3>
        <button type="button" {{on "click" this.fillTestCard}} class="text-xs text-primary-600 hover:underline font-medium">
          Use test card
        </button>
      </div>

      {{!-- Success Alert --}}
      {{#if this.successMessage}}
        <div class="rounded-lg bg-success-50 border border-emerald-200 p-4 space-y-2">
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-success-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm font-medium text-success-700">{{this.successMessage}}</p>
          </div>
          {{#if this.transactionId}}
            <p class="text-[11px] text-success-700 font-mono pl-8">
              Transaction: {{this.transactionId}}
            </p>
          {{/if}}
        </div>
      {{/if}}

      {{!-- Error Alert --}}
      {{#if this.errorMessage}}
        <div class="rounded-lg bg-danger-50 border border-rose-200 p-4 flex items-center gap-3">
          <svg class="h-5 w-5 text-danger-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
          <p class="text-sm font-medium text-danger-600">{{this.errorMessage}}</p>
        </div>
      {{/if}}

      {{#unless this.isAdmin}}
        <div class="rounded-lg bg-warning-50 border border-amber-200 p-4 flex items-center gap-3">
          <svg class="h-5 w-5 text-warning-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
          <p class="text-sm font-medium text-warning-500">
            Only Tenant Administrators can process payments. Sign in as an admin to complete this action.
          </p>
        </div>
      {{/unless}}

      <form {{on "submit" this.processPayment}} class="space-y-5">
        <div>
          <label for="checkout-card-name" class="form-label">Cardholder Name</label>
          <Input
            @type="text"
            @value={{this.cardName}}
            id="checkout-card-name"
            disabled={{not this.isAdmin}}
            required
            class="form-input"
            placeholder="Jane Doe"
          />
        </div>

        <div>
          <label for="checkout-card-number" class="form-label">Card Number</label>
          <Input
            @type="text"
            @value={{this.cardNumber}}
            id="checkout-card-number"
            disabled={{not this.isAdmin}}
            required
            class="form-input"
            placeholder="4242 4242 4242 4242"
          />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="checkout-card-expiry" class="form-label">Expiry</label>
            <Input
              @type="text"
              @value={{this.cardExpiry}}
              id="checkout-card-expiry"
              disabled={{not this.isAdmin}}
              required
              class="form-input"
              placeholder="MM / YY"
            />
          </div>
          <div>
            <label for="checkout-card-cvc" class="form-label">CVC</label>
            <Input
              @type="text"
              @value={{this.cardCvc}}
              id="checkout-card-cvc"
              disabled={{not this.isAdmin}}
              required
              class="form-input"
              placeholder="123"
            />
          </div>
        </div>

        <button
          type="submit"
          disabled={{not this.canSubmit}}
          class="btn-primary w-full btn-lg mt-2"
        >
          {{#if this.isProcessing}}
            <svg class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Processing Payment…
          {{else}}
            Upgrade Now — $99/mo
          {{/if}}
        </button>

        <p class="text-xs text-center text-slate-400 pt-2">
          🔒 This is a demo checkout. No real charges will be made.
          <br/>
          The mock gateway randomly succeeds 80% of the time.
        </p>
      </form>
    </div>
  </div>
</div>

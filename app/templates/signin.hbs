<div class="sm:mx-auto sm:w-full sm:max-w-md">
  {{!-- Logo --}}
  <div class="flex justify-center">
    <div class="h-12 w-12 rounded-xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/25">
      <svg class="w-7 h-7 text-white" width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
    </div>
  </div>
  <h2 class="mt-5 text-center text-2xl font-bold text-slate-900">
    Welcome Back
  </h2>
  <p class="mt-2 text-center text-sm text-slate-500">
    Sign in to your CRM Ecosystem account
  </p>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
  <div class="card">
    <div class="card-body">
      <form class="space-y-5" {{on "submit" this.authenticate}}>

        {{!-- Email Field --}}
        <div>
          <label for="login-email" class="form-label">Email address</label>
          <Input
            id="login-email"
            @type="email"
            @value={{this.email}}
            autocomplete="email"
            required
            class="form-input"
            placeholder="you@company.com"
          />
        </div>

        {{!-- Password Field --}}
        <div>
          <label for="login-password" class="form-label">Password</label>
          <Input
            id="login-password"
            @type="password"
            @value={{this.password}}
            autocomplete="current-password"
            required
            class="form-input"
            placeholder="••••••••"
          />
        </div>

        {{!-- Error Alert --}}
        {{#if this.errorMessage}}
          <div class="rounded-lg bg-danger-50 border border-rose-200 p-4">
            <div class="flex items-center gap-3">
              <svg class="h-5 w-5 text-danger-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
              </svg>
              <p class="text-sm font-medium text-danger-600">{{this.errorMessage}}</p>
            </div>
          </div>
        {{/if}}

        {{!-- Submit --}}
        <button
          type="submit"
          disabled={{this.isProcessing}}
          class="btn-primary w-full"
        >
          {{#if this.isProcessing}}
            <svg class="animate-spin -ml-1 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Signing in…
          {{else}}
            Sign In
          {{/if}}
        </button>
      </form>

      {{!-- Demo Credentials --}}
      <div class="mt-6 pt-5 border-t border-slate-100">
        <p class="text-center text-xs text-slate-400">
          Demo credentials:
          <span class="font-mono text-slate-500">admin@acme.example.com</span>
          /
          <span class="font-mono text-slate-500">password123</span>
        </p>
      </div>

      <div class="mt-6 space-y-4">
        <div>
          <h3 class="text-sm font-semibold text-slate-900">Multi-tenant demo accounts</h3>
          <p class="mt-1 text-xs text-slate-500">Click any account to fill the form instantly.</p>
        </div>
        <div class="grid gap-3">
          {{#each this.demoTenants as |tenant|}}
            <div class="rounded-2xl border border-slate-200 p-4 {{tenant.accent}}">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="font-semibold">{{tenant.name}}</p>
                  <p class="text-xs opacity-80">{{tenant.subdomain}} tenant</p>
                </div>
                <span class="text-[10px] uppercase tracking-[0.2em]">Demo</span>
              </div>
              <div class="mt-3 grid grid-cols-2 gap-2">
                {{#each this.demoRoles as |role|}}
                  <button
                    type="button"
                    {{on "click" (fn this.useDemo tenant role)}}
                    class="rounded-lg bg-white/70 px-3 py-2 text-left text-xs font-medium text-slate-700 hover:bg-white transition-colors"
                  >
                    {{role.label}}
                  </button>
                {{/each}}
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>
</div>

<div class="space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Companies</h1>
      <p class="mt-1 text-sm text-slate-500">Manage your business accounts and organizations.</p>
    </div>
    <div class="flex flex-wrap gap-2 self-start">
      {{#if (this.permissions.can "companies" "export")}}
        <button type="button" {{on "click" this.exportCsv}} class="btn-secondary">
          Export CSV
        </button>
      {{/if}}

      {{#if (this.permissions.can "companies" "write")}}
        <button type="button" {{on "click" this.openCreate}} class="btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add Company
        </button>
      {{/if}}
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {{#each this.companies as |company|}}
      <div class="card group hover:border-primary-200 hover:shadow-md transition-all duration-200">
        <div class="card-body">
          <div class="flex items-start justify-between gap-2">
            <div class="flex items-center gap-3 min-w-0">
              <div class="h-11 w-11 rounded-lg bg-slate-100 flex items-center justify-center text-slate-600 font-bold text-sm flex-shrink-0 group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors">
                {{substring company.name 0 2}}
              </div>
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-slate-900 group-hover:text-primary-600 transition-colors truncate">{{company.name}}</h3>
                {{#if company.industry}}
                  <p class="text-xs text-slate-400 truncate">{{company.industry}}</p>
                {{/if}}
              </div>
            </div>
            <div class="flex gap-1 flex-shrink-0">
              {{#if (this.permissions.can "companies" "write")}}
                <button type="button" {{on "click" (fn this.openEdit company)}} class="text-slate-300 hover:text-primary-600 p-1" title="Edit">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                  </svg>
                </button>
              {{/if}}
              {{#if (this.permissions.can "companies" "delete")}}
                <button type="button" {{on "click" (fn this.deleteCompany company)}} class="text-slate-300 hover:text-danger-500 p-1" title="Delete">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              {{/if}}
            </div>
          </div>

          {{#if company.website}}
            <div class="mt-4 flex items-center gap-2 text-xs text-slate-500">
              <svg class="h-3.5 w-3.5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
              <span class="truncate">{{company.website}}</span>
            </div>
          {{/if}}
        </div>
      </div>
    {{else}}
      <div class="col-span-full card">
        <div class="card-body py-16 text-center">
          <p class="text-sm font-medium text-slate-600">No companies yet</p>
          <p class="text-xs text-slate-400 mt-1">Click "Add Company" to create your first account.</p>
        </div>
      </div>
    {{/each}}
  </div>
</div>

{{#if this.showCreateModal}}
  <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/50">
    <div class="card w-full max-w-md shadow-2xl">
      <div class="card-header">
        <h2 class="text-base font-semibold text-slate-900">
          {{if this.editingCompany "Edit Company" "New Company"}}
        </h2>
        <button type="button" {{on "click" this.closeModal}} class="text-slate-400 hover:text-slate-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form {{on "submit" this.saveCompany}} class="card-body space-y-4">
        {{#if this.saveError}}
          <div class="rounded-lg bg-danger-50 border border-rose-200 p-3 text-xs text-danger-600">
            {{this.saveError}}
          </div>
        {{/if}}
        <div>
          <label for="company-name" class="form-label">Name</label>
          <Input id="company-name" @type="text" @value={{this.formName}} required class="form-input" />
        </div>
        <div>
          <label for="company-industry" class="form-label">Industry</label>
          <Input id="company-industry" @type="text" @value={{this.formIndustry}} class="form-input" placeholder="SaaS, Retail, etc." />
        </div>
        <div>
          <label for="company-website" class="form-label">Website</label>
          <Input id="company-website" @type="text" @value={{this.formWebsite}} class="form-input" placeholder="example.com" />
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" {{on "click" this.closeModal}} class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-primary">
            {{if this.editingCompany "Save Changes" "Create Company"}}
          </button>
        </div>
      </form>
    </div>
  </div>
{{/if}}

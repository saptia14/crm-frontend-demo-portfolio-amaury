<div class="min-h-screen bg-slate-50">
  {{#if this.session.isAuthenticated}}
    {{!-- Top bar --}}
    <header class="bg-primary-700 text-white shadow-sm">
      <div class="px-4 sm:px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="h-8 w-8 rounded-lg bg-white/15 flex items-center justify-center">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h1 class="font-bold text-base sm:text-lg flex items-center gap-2">
            <span>CRM Ecosystem</span>
            {{#if this.currentUser.user.tenant.name}}
              <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-white/20 text-white border border-white/10">
                {{this.currentUser.user.tenant.name}}
              </span>
            {{/if}}
          </h1>
        </div>
        <div class="flex items-center gap-3">
          <div class="hidden sm:flex flex-col items-end leading-tight">
            <span class="text-xs text-primary-100">{{this.currentUser.user.email}}</span>
            <span class="text-[10px] uppercase tracking-wider text-primary-200">
              {{this.currentUser.user.role}}
            </span>
          </div>
          <button
            type="button"
            {{on "click" this.logout}}
            class="px-3 py-1.5 bg-white/15 rounded-md hover:bg-white/25 transition-colors text-xs font-medium"
          >
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <div class="flex">
      {{!-- Sidebar --}}
      <aside class="w-56 bg-slate-900 min-h-[calc(100vh-56px)] p-3 text-slate-300 hidden md:block">
        <nav class="space-y-1 text-sm">
          <LinkTo
            @route="dashboard"
            @current-when="dashboard"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition-colors"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Dashboard
          </LinkTo>
          <LinkTo
            @route="contacts"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition-colors"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Contacts
          </LinkTo>
          <LinkTo
            @route="deals"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition-colors"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Deals
          </LinkTo>
          {{#if (this.permissions.can "companies" "read")}}
            <LinkTo
              @route="companies"
              class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              Companies
            </LinkTo>
          {{/if}}

          {{#if (this.permissions.can "users" "read")}}
            <LinkTo
              @route="users"
              class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              Team
            </LinkTo>
          {{/if}}

          <div class="pt-4 mt-4 border-t border-slate-800">
            <LinkTo
              @route="checkout"
              class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary-600/10 text-primary-300 hover:bg-primary-600/20 hover:text-primary-200 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              Upgrade to Pro
            </LinkTo>
          </div>
        </nav>
      </aside>

      {{!-- Mobile nav (visible <md) --}}
      <nav class="md:hidden fixed bottom-0 inset-x-0 bg-slate-900 text-slate-300 border-t border-slate-800 z-20">
        <div class="flex items-center justify-between text-[10px] text-center">
          <LinkTo @route="dashboard" class="flex-1 py-2 hover:text-white">Home</LinkTo>
          {{#if (this.permissions.can "users" "read")}}
            <LinkTo @route="users" class="flex-1 py-2 hover:text-white">Team</LinkTo>
          {{/if}}
          <LinkTo @route="contacts" class="flex-1 py-2 hover:text-white">Contacts</LinkTo>
          <LinkTo @route="deals" class="flex-1 py-2 hover:text-white">Deals</LinkTo>
          {{#if (this.permissions.can "companies" "read")}}
            <LinkTo @route="companies" class="flex-1 py-2 hover:text-white">Companies</LinkTo>
          {{/if}}
          <LinkTo @route="checkout" class="flex-1 py-2 text-primary-300">Upgrade</LinkTo>
        </div>
      </nav>

      <main class="flex-1 p-4 sm:p-6 md:p-8 pb-20 md:pb-8 min-w-0">
        {{outlet}}
      </main>
    </div>
  {{else}}
    <div class="min-h-screen flex items-center justify-center">
      {{outlet}}
    </div>
  {{/if}}
</div>

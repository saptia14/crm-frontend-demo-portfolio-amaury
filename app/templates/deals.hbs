<div class="space-y-6">
  {{!-- Page Header --}}
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Deals</h1>
      <p class="mt-1 text-sm text-slate-500">
        {{this.totalDeals}}
        {{if (eq this.totalDeals 1) "deal" "deals"}}
        in your pipeline.
      </p>
    </div>
    <div class="flex flex-wrap gap-2 self-start">
      {{#if (this.permissions.can "deals" "export")}}
        <button type="button" {{on "click" this.exportCsv}} class="btn-secondary">
          Export CSV
        </button>
      {{/if}}

      {{#if (this.permissions.can "deals" "write")}}
        <button type="button" {{on "click" this.openCreate}} class="btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Deal
        </button>
      {{/if}}
    </div>
  </div>

  {{!-- Filter Bar --}}
  <div class="card">
    <div class="card-body">
      <form {{on "submit" this.applyFilters}} class="flex flex-col md:flex-row gap-3">
        <div class="flex-1">
          <Input
            @type="search"
            @value={{this.q}}
            class="form-input"
            placeholder="Search by deal name..."
          />
        </div>
        <div class="w-full md:w-48">
          <select class="form-input" {{on "change" this.setStageFilter}}>
            <option value="" selected={{eq this.stage ""}}>All stages</option>
            {{#each this.stages as |stageOption|}}
              <option value={{stageOption}} selected={{eq stageOption this.stage}}>
                {{stageOption}}
              </option>
            {{/each}}
          </select>
        </div>
        <div class="w-full md:w-48">
          <Input
            @type="text"
            @value={{this.tags}}
            class="form-input"
            placeholder="Tags (urgent, vip)"
          />
        </div>
        <button type="submit" class="btn-secondary">Filter</button>
        {{#if this.hasFilters}}
          <button type="button" {{on "click" this.clearFilters}} class="btn-ghost">
            Clear
          </button>
        {{/if}}
      </form>
    </div>
  </div>

  {{!-- Deals Table --}}
  <div class="card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Deal</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Amount</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Stage</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider hidden sm:table-cell">Close Date</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          {{#each this.deals as |deal|}}
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <div class="h-8 w-8 rounded-lg
                    {{if deal.isWon "bg-success-50 text-success-600"
                      (if deal.isLost "bg-danger-50 text-danger-500" "bg-primary-50 text-primary-600")
                    }}
                    flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 1v8m0 0v1"/>
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-slate-900 truncate max-w-xs">{{deal.name}}</p>
                    <p class="text-xs text-slate-400 truncate">{{deal.company.name}}</p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-slate-900">
                ${{format-money deal.amount}}
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="
                  {{if deal.isWon "badge-success"
                    (if deal.isLost "badge-danger" "badge-primary")
                  }}
                ">
                  {{deal.stage}}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 hidden sm:table-cell">
                {{if deal.expectedCloseDate deal.expectedCloseDate "—"}}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <div class="flex items-center justify-end gap-2">
                  {{#if (and deal.isOpen this.currentUser.user.isSalesRep)}}
                    <button
                      type="button"
                      {{on "click" (fn this.assignToMe deal)}}
                      class="btn-ghost btn-sm"
                    >
                      Assign to me
                    </button>
                  {{/if}}
                  {{#if (this.permissions.can "deals" "write")}}
                    <button
                      type="button"
                      {{on "click" (fn this.openEdit deal)}}
                      class="text-slate-300 hover:text-primary-600 transition-colors p-1"
                      title="Edit"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                      </svg>
                    </button>
                  {{/if}}
                  {{#if (this.permissions.can "deals" "delete")}}
                    <button
                      type="button"
                      {{on "click" (fn this.deleteDeal deal)}}
                      class="text-slate-300 hover:text-danger-500 transition-colors p-1"
                      title="Delete"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    </button>
                  {{/if}}
                </div>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="5" class="px-6 py-16 text-center">
                <div class="flex flex-col items-center">
                  <div class="h-12 w-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 mb-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <p class="text-sm font-medium text-slate-600">No deals found</p>
                  <p class="text-xs text-slate-400 mt-1">
                    {{#if this.hasFilters}}
                      Try adjusting your filters or
                      <button type="button" {{on "click" this.clearFilters}} class="text-primary-600 hover:underline">clear them</button>.
                    {{else}}
                      Create your first deal to get started.
                    {{/if}}
                  </p>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>

{{!-- Create / Edit Modal --}}
{{#if this.showCreateModal}}
  <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/50 overflow-y-auto">
    <div class="card w-full max-w-lg shadow-2xl my-8">
      <div class="card-header">
        <h2 class="text-base font-semibold text-slate-900">
          {{if this.editingDeal "Edit Deal" "New Deal"}}
        </h2>
        <button type="button" {{on "click" this.closeModal}} class="text-slate-400 hover:text-slate-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form {{on "submit" this.saveDeal}} class="card-body space-y-4">
        {{#if this.saveError}}
          <div class="rounded-lg bg-danger-50 border border-rose-200 p-3 text-xs text-danger-600">
            {{this.saveError}}
          </div>
        {{/if}}
        <div>
          <label for="deal-name" class="form-label">Deal Name</label>
          <Input id="deal-name" @type="text" @value={{this.formName}} required class="form-input" placeholder="Q3 Enterprise Upgrade" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="deal-amount" class="form-label">Amount (USD)</label>
            <Input id="deal-amount" @type="number" @value={{this.formAmount}} required class="form-input" placeholder="50000" />
          </div>
          <div>
            <label for="deal-stage" class="form-label">Stage</label>
            <select id="deal-stage" class="form-input" {{on "change" (fn this.setFormField "formStage")}}>
              {{#each this.stages as |stageOption|}}
                <option value={{stageOption}} selected={{eq stageOption this.formStage}}>{{stageOption}}</option>
              {{/each}}
            </select>
          </div>
        </div>
        <div>
          <label for="deal-close" class="form-label">Expected Close Date</label>
          <Input id="deal-close" @type="date" @value={{this.formCloseDate}} class="form-input" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="deal-contact" class="form-label">Contact</label>
            <select id="deal-contact" class="form-input" {{on "change" (fn this.setFormField "formContactId")}}>
              <option value="">— None —</option>
              {{#each this.contacts as |c|}}
                <option value={{c.id}} selected={{eq this.formContactId c.id}}>{{c.fullName}}</option>
              {{/each}}
            </select>
          </div>
          <div>
            <label for="deal-company" class="form-label">Company</label>
            <select id="deal-company" class="form-input" {{on "change" (fn this.setFormField "formCompanyId")}}>
              <option value="">— None —</option>
              {{#each this.companies as |co|}}
                <option value={{co.id}} selected={{eq this.formCompanyId co.id}}>{{co.name}}</option>
              {{/each}}
            </select>
          </div>
        </div>
        <div>
          <label for="deal-tags" class="form-label">Tags <span class="text-slate-400 font-normal">(comma-separated)</span></label>
          <Input id="deal-tags" @type="text" @value={{this.formTags}} class="form-input" placeholder="enterprise, urgent" />
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" {{on "click" this.closeModal}} class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-primary">
            {{if this.editingDeal "Save Changes" "Create Deal"}}
          </button>
        </div>
      </form>
    </div>
  </div>
{{/if}}
